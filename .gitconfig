[core]
    editor = vi
    ignorecase = false

# Aliases are command shortcuts
[alias]
    sw = switch

    # lg is now a shortcut for a pretty log with short commit messages
    # See the log manpage: https://www.kernel.org/pub/software/scm/git/docs/git-log.html
    # for explanations of what these options do
    lg = log \
        --graph \
        --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' \
        --abbrev-commit \
        --date=relative

    ci = commit
    s = status
    a = add -A
    b = branch
    p = pull
    ph = push -u origin HEAD --tags
    d = diff --diff-algorithm=histogram
    dc = diff --cached --diff-algorithm=histogram

[user]
	name = JC (Jonathan Chen)

[commit]
    template = ~/.gitmessage

[merge]
	conflictstyle = zdiff3

# TODO: remove when git 3, since main will be default
[init]
	defaultBranch = main
